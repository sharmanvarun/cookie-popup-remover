{
  "manifest_version": 3,
  "name": "Cookie Popup Remover",
  "version": "1.0.0",
  "description": "Removes cookie-consent popups and their scroll-lock so you can use pages like vg.no freely.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "Cookie Popup Remover",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["core.js", "content.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "commands": {
    "remove-now": {
      "suggested_key": {
        "default": "Alt+Shift+C"
      },
      "description": "Remove cookie pop-up on the current page"
    }
  }
}
